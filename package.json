{
  "name": "opencode-telegram",
  "version": "0.7.0",
  "type": "module",
  "description": "Telegram bot that orchestrates multiple OpenCode instances through forum topics",
  "author": "tadaokatzuki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tadaokatzuki/opencode-telegram.git"
  },
  "bugs": {
    "url": "https://github.com/tadaokatzuki/opencode-telegram/issues"
  },
  "homepage": "https://github.com/tadaokatzuki/opencode-telegram#readme",
  "keywords": [
    "telegram",
    "bot",
    "opencode",
    "ai",
    "coding-assistant",
    "grammy",
    "bun",
    "forum-topics",
    "multi-instance"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "lint": "./node_modules/.bin/tsc --noEmit",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "grammy": "^1.42.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
