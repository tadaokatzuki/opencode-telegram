{
  "name": "opencode-orquestrator",
  "version": "0.8.0",
  "type": "module",
  "description": "Orchestrates multiple OpenCode instances via Telegram topics and WhatsApp groups",
  "author": "huynle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tadaokatzuki/opencode-orquestrator.git"
  },
  "bugs": {
    "url": "https://github.com/tadaokatzuki/opencode-orquestrator/issues"
  },
  "homepage": "https://github.com/tadaokatzuki/opencode-orquestrator#readme",
  "keywords": [
    "telegram",
    "whatsapp",
    "bot",
    "opencode",
    "ai",
    "orquestrator",
    "coding-assistant",
    "grammy",
    "bun",
    "forum-topics",
    "multi-instance"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "lint": "./node_modules/.bin/tsc --noEmit",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "install:deps": "npm install"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.5.3",
    "better-sqlite3": "^12.9.0",
    "bun": "^1.3.13",
    "grammy": "^1.42.0",
    "protobufjs": "7.5.5",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
"devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.1.0",
    "adm-zip": "^0.5.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "protobufjs": "7.5.5",
    "@whiskeysockets/libsignal-node>protobufjs": "7.5.5",
    "@whiskeysockets/baileys>libsignal>protobufjs": "7.5.5"
  }
}
}
