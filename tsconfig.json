{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "rootDir": "src",
    "types": ["node", "better-sqlite3", "bun-types"],
    "lib": ["ES2022"]
  },
  "include": ["src"]
}
